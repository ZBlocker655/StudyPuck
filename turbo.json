{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "APP_ENV",
    "AUTH_SECRET",
    "AUTH0_CLIENT_ID",
    "AUTH0_CLIENT_SECRET",
    "AUTH0_ISSUER",
    "AUTH0_AUDIENCE",
    "DATABASE_URL",
    "DEV_DATABASE_URL",
    "PROD_DATABASE_URL",
    "TEST_DATABASE_URL",
    "NEON_API_KEY",
    "E2E_TEST_MODE",
    "PLAYWRIGHT_BASE_URL",
    "PLAYWRIGHT_PORT",
    "PLAYWRIGHT_MANAGED_SERVER"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".svelte-kit/**", ".vercel/**", "build/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "cache": false,
      "outputs": ["apps/web/test-results/**", "apps/web/playwright-report/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
