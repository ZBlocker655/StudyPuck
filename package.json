{
  "name": "studypuck",
  "private": true,
  "description": "A language learning app using AI-powered translation drills and spaced repetition",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:secure": "node scripts/run-with-bitwarden-env.mjs -- pnpm --filter web dev",
    "dev:workers:secure": "node scripts/run-with-bitwarden-env.mjs --set ORIGIN=http://127.0.0.1:8788 -- pnpm --filter web dev:workers",
    "db:generate:secure": "node scripts/run-with-bitwarden-env.mjs -- pnpm --filter @studypuck/database migrate:generate",
    "db:migrate:secure": "node scripts/run-with-bitwarden-env.mjs -- pnpm --filter @studypuck/database migrate:apply",
    "db:studio:secure": "node scripts/run-with-bitwarden-env.mjs -- pnpm --filter @studypuck/database migrate:studio",
    "env:check:secure": "node scripts/run-with-bitwarden-env.mjs --check",
    "env:scan:secure": "node scripts/run-with-bitwarden-env.mjs --scan",
    "test": "turbo test",
    "lint": "turbo lint",
    "check-types": "turbo check-types",
    "format": "prettier --write .",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2.7.2",
    "varlock": "^0.6.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
